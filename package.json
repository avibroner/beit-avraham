{
  "name": "beit-avraham-tools",
  "version": "0.1.0",
  "private": true,
  "description": "CLI tools for the beit-avraham site (curated link creation, etc.). The site itself is static HTML and does not depend on this package.",
  "scripts": {
    "create-link": "node scripts/create-link.js",
    "optimize:images": "node scripts/optimize-print-images.js",
    "pdf": "node scripts/optimize-print-images.js && node scripts/generate-pdf.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "pdfjs-dist": "^5.6.205",
    "puppeteer": "^23.11.1",
    "sharp": "^0.34.5"
  }
}
